{
  "name": "nest-auth-example",
  "version": "0.0.1",
  "private": true,
  "description": "Nest.js authentication with Passport. Realworld example",
  "license": "MIT",
  "author": "Jaime Leonardo Suncin Cruz <leosuncin@gmail.com>",
  "scripts": {
    "build": "nest build",
    "db:create": "ts-node -r dotenv-mono/load -r tsconfig-paths/register node_modules/typeorm-extension/bin/cli.mjs db:create -r src/config --synchronize=no --initialDatabase=postgres",
    "db:drop": "ts-node -r dotenv-mono/load -r tsconfig-paths/register node_modules/typeorm-extension/bin/cli.mjs db:drop -r src/config --initialDatabase=postgres",
    "db:seed": "ts-node -r dotenv-mono/load -r tsconfig-paths/register node_modules/typeorm-extension/bin/cli.mjs seed:run -r src/config",
    "format": "ultracite fix",
    "lint": "ultracite check",
    "migration:run": "typeorm migration:run -d dist/data-source",
    "start": "node dist/main.js",
    "start:debug": "NODE_OPTIONS='-r dotenv-mono/load' nest start --debug --watch",
    "start:dev": "NODE_OPTIONS='-r dotenv-mono/load' nest start --watch",
    "start:repl": "NODE_OPTIONS='-r dotenv-mono/load' nest start --entryFile repl",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch",
    "typeorm": "NODE_OPTIONS='-r dotenv-mono/load -r tsconfig-paths/register' typeorm-ts-node-commonjs -d src/data-source"
  },
  "jest": {
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "setupFiles": [
      "dotenv-mono/load"
    ],
    "testEnvironment": "node",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.17.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@devoxa/integresql-client": "^2.0.0",
    "@faker-js/faker": "^10.0.0",
    "@jackfranklin/test-data-bot": "^2.0.0",
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@suites/di.nestjs": "^3.1.0",
    "@suites/doubles.jest": "^3.1.0",
    "@suites/unit": "^3.1.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.17.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.34",
    "@types/supertest": "^2.0.12",
    "@usebruno/cli": "^3.4.2",
    "dotenv-mono": "^1.3.10",
    "jest": "^30.0.0",
    "node-mocks-http": "^1.12.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm-extension": "^4.0.0-beta.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3"
  },
  "allowScripts": {
    "@suites/di.nestjs@3.1.0": true,
    "@suites/doubles.jest@3.1.0": true,
    "unrs-resolver@1.12.2": true
  }
}
